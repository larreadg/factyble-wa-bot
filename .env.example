NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

# Meta WhatsApp Cloud API
WHATSAPP_API_VERSION=v21.0
WHATSAPP_APP_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Database
DATABASE_URL="file:../factyble-bot.db"
DATABASE_BUSY_TIMEOUT_MS=5000

# External billing backend
BILLING_BACKEND_BASE_URL=
BILLING_BACKEND_API_KEY=
BILLING_BACKEND_TIMEOUT_MS=15000

# Session engine
SESSION_DEFAULT_TTL_MINUTES=30
SESSION_LOCK_TTL_SECONDS=30
SESSION_MAX_INVALID_ATTEMPTS=3
SESSION_EXTERNAL_WAIT_TTL_MINUTES=10
