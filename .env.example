# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# REST API auth
API_KEY=

# Clave hex de 32 bytes (64 caracteres) para cifrar/descifrar credenciales (ej. Empresa.password)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Meta WhatsApp Cloud API
WHATSAPP_API_VERSION=
WHATSAPP_APP_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# OpenAI (parser conversacional de facturas)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REASONING_EFFORT=none
OPENAI_PROMPT_CACHE_KEY=factyble:invoice-parser:v1
OPENAI_MAX_OUTPUT_TOKENS=1000
OPENAI_TIMEOUT_MS=15000

# API de facturación (emisión real de comprobantes, POST /factura/simple)
FACTURACION_API_BASE_URL=
FACTURACION_API_TIMEOUT_MS=30000

# Telegram (detalle .txt de cada chat al finalizar/cancelarse)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Barrido de sesiones abandonadas/atascadas (opcional, tienen default razonable en env.js)
# SESION_INACTIVA_TIMEOUT_MS=86400000
# SESION_PROCESANDO_TIMEOUT_MS=900000
# SESION_BARRIDO_INTERVALO_MS=600000

# DOCKER APP
DOCKER_APP_HOST_PORT=
DOCKER_APP_CONTAINER_PORT=
