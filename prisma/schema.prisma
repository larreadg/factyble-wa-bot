generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Empresa {
  id                Int       @id @default(autoincrement())
  ruc               String    @unique
  razonSocial       String    @map("razon_social")
  usuario           String
  // Cifrado reversible (AES-256-GCM, ver src/utils/crypto.js), no un hash:
  // se necesita descifrar para autenticarse contra la API externa.
  password          String    @db.Text
  token             String?   @db.Text
  tokenExpiracion   DateTime? @map("token_expiracion")
  fechaCreacion     DateTime  @default(now()) @map("fecha_creacion")
  fechaModificacion DateTime  @updatedAt @map("fecha_modificacion")

  contactos  Contacto[]
  documentos Documento[]

  @@map("empresa")
}

model Contacto {
  id                Int      @id @default(autoincrement())
  empresaId         Int      @map("empresa_id")
  numeroTelefono    String   @unique @map("numero_telefono")
  whatsappId        String?  @unique @map("whatsapp_id")
  nombre            String?
  activo            Boolean  @default(true)
  fechaCreacion     DateTime @default(now()) @map("fecha_creacion")
  fechaModificacion DateTime @updatedAt @map("fecha_modificacion")

  empresa        Empresa        @relation(fields: [empresaId], references: [id])
  conversaciones Conversacion[]

  @@index([empresaId])
  @@map("contacto")
}

enum EstadoConversacion {
  ABIERTA
  CERRADA
}

// El índice único parcial (contacto_id) WHERE estado = 'ABIERTA' no es representable
// en el DSL de Prisma para MySQL: se implementa en la migración con una columna
// generada + índice único (ver migration.sql). Si este modelo cambia, preservar
// esa columna/índice manualmente en la nueva migración.
model Conversacion {
  id                 Int                @id @default(autoincrement())
  contactoId         Int                @map("contacto_id")
  estado             EstadoConversacion @default(ABIERTA)
  fechaInicio        DateTime           @map("fecha_inicio")
  fechaUltimoMensaje DateTime?          @map("fecha_ultimo_mensaje")
  fechaCierre        DateTime?          @map("fecha_cierre")
  fechaCreacion      DateTime           @default(now()) @map("fecha_creacion")
  fechaModificacion  DateTime           @updatedAt @map("fecha_modificacion")

  // onUpdate: Restrict porque contacto_id es columna base de la generada
  // contacto_id_abierta (ver arriba); MySQL prohibe ON UPDATE CASCADE en ese caso.
  contacto Contacto              @relation(fields: [contactoId], references: [id], onUpdate: Restrict)
  mensajes Mensaje[]
  sesion   SesionConversacional?

  @@index([contactoId])
  @@index([estado])
  @@index([fechaUltimoMensaje])
  @@map("conversacion")
}

enum DireccionMensaje {
  ENTRANTE
  SALIENTE
}

enum TipoMensaje {
  TEXTO
  AUDIO
  IMAGEN
  DOCUMENTO
}

enum EstadoMensaje {
  RECIBIDO
  PENDIENTE
  ENVIADO
  ENTREGADO
  LEIDO
  FALLIDO
}

model Mensaje {
  id                Int              @id @default(autoincrement())
  conversacionId    Int              @map("conversacion_id")
  whatsappMensajeId String?          @unique @map("whatsapp_mensaje_id")
  direccion         DireccionMensaje
  tipo              TipoMensaje
  contenidoTexto    String?          @map("contenido_texto") @db.Text
  estado            EstadoMensaje
  fechaMensaje      DateTime         @map("fecha_mensaje")
  fechaCreacion     DateTime         @default(now()) @map("fecha_creacion")
  fechaModificacion DateTime         @updatedAt @map("fecha_modificacion")

  conversacion          Conversacion           @relation(fields: [conversacionId], references: [id])
  archivo               MensajeArchivo?
  sesionesUltimoMensaje SesionConversacional[]

  @@index([conversacionId])
  @@index([estado])
  @@index([fechaMensaje])
  @@index([conversacionId, fechaMensaje])
  @@map("mensaje")
}

model MensajeArchivo {
  id                Int      @id @default(autoincrement())
  mensajeId         Int      @unique @map("mensaje_id")
  whatsappMediaId   String?  @map("whatsapp_media_id")
  nombreArchivo     String?  @map("nombre_archivo")
  mimeType          String   @map("mime_type")
  tamanioBytes      Int?     @map("tamanio_bytes")
  rutaArchivo       String?  @map("ruta_archivo")
  transcripcion     String?  @db.Text
  fechaCreacion     DateTime @default(now()) @map("fecha_creacion")
  fechaModificacion DateTime @updatedAt @map("fecha_modificacion")

  mensaje Mensaje @relation(fields: [mensajeId], references: [id])

  @@index([whatsappMediaId])
  @@map("mensaje_archivo")
}

model SesionConversacional {
  id                Int       @id @default(autoincrement())
  conversacionId    Int       @unique @map("conversacion_id")
  intencionActual   String?   @map("intencion_actual")
  operacionActiva   String?   @map("operacion_activa")
  estado            String
  datosTemporales   Json      @default("{}") @map("datos_temporales")
  ultimoMensajeId   Int?      @map("ultimo_mensaje_id")
  fechaExpiracion   DateTime? @map("fecha_expiracion")
  fechaCreacion     DateTime  @default(now()) @map("fecha_creacion")
  fechaModificacion DateTime  @updatedAt @map("fecha_modificacion")

  conversacion  Conversacion @relation(fields: [conversacionId], references: [id])
  ultimoMensaje Mensaje?     @relation(fields: [ultimoMensajeId], references: [id])

  @@index([estado])
  @@index([fechaExpiracion])
  @@map("sesion_conversacional")
}

enum TipoDocumento {
  FACTURA
  NOTA_CREDITO
}

// Ver tabla de estados en la doc de la API de facturación: GENERADO/FIRMANDO son
// transitorios y no llegan a verse acá; FIRMADO es el estado justo tras /simple
// (pendiente de envío a SIFEN por el cron del backend de facturación); APROBADO/
// RECHAZADO/ERROR son los estados finales que el bot espera antes de avisarle al
// cliente; CANCELADO es el resultado de /simple/cancelar.
enum EstadoSifenDocumento {
  GENERADO
  FIRMANDO
  FIRMADO
  ENCOLADO
  ENVIADO
  APROBADO
  RECHAZADO
  ERROR
  CANCELADO
}

// Registro local de cada factura/nota de crédito emitida (o cancelada) por el bot.
// numeroTelefono guarda el identificador de WhatsApp del contacto directamente acá
// (en vez de resolverlo vía Contacto/Conversacion) para que el servicio que actualiza
// estadoSifen en bulk (POST /documento/bulk-update) pueda enviarle el PDF al cliente
// sin recorrer el resto del modelo.
model Documento {
  id                        Int                   @id @default(autoincrement())
  empresaId                 Int                   @map("empresa_id")
  numeroTelefono            String                @map("numero_telefono")
  tipo                      TipoDocumento
  cdc                       String                @unique @db.VarChar(44)
  pdfNombre                 String?               @map("pdf_nombre")
  numeroDocumentoFormateado String?               @map("numero_documento_formateado")
  clienteNombre             String?               @map("cliente_nombre")
  clienteDocumento          String?               @map("cliente_documento")
  estadoSifen               EstadoSifenDocumento? @map("estado_sifen")
  sifenEstadoMensaje        String?               @map("sifen_estado_mensaje") @db.Text
  // Cuándo se le avisó al cliente el resultado final (APROBADO/RECHAZADO/ERROR). Null =
  // pendiente de avisar. Evita reenviar el PDF/mensaje si bulk-update recibe el mismo
  // cdc más de una vez (reintentos del backend de facturación) y hace que el aviso sea
  // autocontenido: se re-evalúa toda la tabla en cada llamada, no solo el batch recibido.
  notificadoEn              DateTime?             @map("notificado_en")
  fechaCreacion             DateTime              @default(now()) @map("fecha_creacion")
  fechaModificacion         DateTime              @updatedAt @map("fecha_modificacion")

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@index([estadoSifen])
  @@index([estadoSifen, notificadoEn])
  @@map("documento")
}
